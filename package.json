{
  "name": "omp-learner",
  "version": "0.4.4",
  "description": "Persistent OMP learner watchdog configuration.",
  "type": "module",
  "scripts": {
    "build:linux-parent-death-helper": "cc -O2 -static -s -o omp-plugin/learner/bin/omp-learner-pdeath-linux-x64 omp-plugin/learner/bin/omp-learner-pdeath.c",
    "test": "node scripts/verify-learner.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klondikemarlen/omp-learner.git"
  },
  "keywords": ["omp-plugin", "learner"],
  "files": [
    "omp-plugin/",
    "scripts/"
  ],
  "omp": {
    "extensions": ["./omp-plugin/index.ts"]
  },
  "pi": {
    "extensions": ["./omp-plugin/index.ts"]
  }
}
